# WereCode Next/Vercel Configuration

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://olquywzupxszttgiptco.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
# Server-only. Required for local dev identity mode while NEXT_PUBLIC_AUTH_ENABLED=false.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Local development only. Never set this in Vercel preview or production.
WERECODE_ENABLE_DEV_IDENTITY=true
WERECODE_DEV_USER_ID=your_auth_users_uuid_here

# Local development only. Shows YouTube URL download controls and imports files
# from the legacy FastAPI backend running on your machine.
NEXT_PUBLIC_ENABLE_LOCAL_YOUTUBE_DOWNLOAD=false
LOCAL_WERECODE_API_URL=http://localhost:8001
LOCAL_YOUTUBE_DOWNLOAD_TIMEOUT_MS=600000
LOCAL_YOUTUBE_DOWNLOAD_POLL_MS=2000
# Optional. Set only if uv/yt-dlp cannot discover Node 22+ for YouTube challenge solving.
YTDLP_NODE_PATH=/Users/<you>/.nvm/versions/node/v22.20.0/bin/node
# Optional fallback for YouTube's "confirm you're not a bot" block.
YTDLP_COOKIEFILE=
YTDLP_COOKIES_BROWSER=chrome

# Developer surface. The Pipeline tab (job/version internals) is auto-shown in
# local `next dev` and hidden everywhere else. Set to true to also expose it and
# the /pipeline route in a deployed (preview/production) environment.
NEXT_PUBLIC_ENABLE_PIPELINE=false

# Modal gateway for heavy media/model work
MODAL_GATEWAY_URL=https://abhirooprasad--werecode-modal-apis-fastapi-app.modal.run
# Optional, only after gateway auth is enabled
MODAL_GATEWAY_TOKEN=

# Site/auth
# Local callback to add in Supabase Auth URL Configuration:
# http://localhost:3000/api/auth/callback
# Production callback:
# https://<your-vercel-domain>/api/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_ENABLED=false

# OpenAI API Key, required only for AI chat/edit workflows
OPENAI_API_KEY=your_openai_api_key_here

# Legacy FastAPI Configuration
# Kept temporarily while the old backend is used as migration reference.

API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true

# File Organization
# Base directories for downloads and outputs
DOWNLOADS_DIR=downloads
OUTPUTS_DIR=outputs

# Song Folder Structure
# When true, creates downloads/<song_title>/ for each song
# When false, all files go directly into DOWNLOADS_DIR
ORGANIZE_BY_SONG=true

# Subfolder names within each song folder
STEMS_SUBFOLDER=stems
ANALYSIS_SUBFOLDER=analysis

# Analysis Configuration
# Transpose chord progressions to target key (e.g., C, A, F#, Bb)
TRANSPOSE_TO_KEY=

# Default analysis preset (quick, full, production, chord, structure)
DEFAULT_ANALYSIS_PRESET=full

# Job Configuration
JOB_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_JOBS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=werecode.log
